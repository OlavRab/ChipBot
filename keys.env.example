DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback

# Web app
SECRET_KEY=
WEB_PORT=5000UPLOAD_URL=https://chipbot-production.up.railway.app

# Revolut payment links (set after creating them in Revolut Pro)
